<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Location (GPS) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Servidor WebSocket local: precisa escutar em todas as interfaces -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Foreground Service - dataSync funciona em Android 10/11/12/13/14 sem property extra -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Auto-start on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Screen overlay for diagnostics -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Keep screen on / Wake lock for field operation -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Accessibility for telemetry capture -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- External storage for logs export (Android 9 and below) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".CollectorApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DroneCollector"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        tools:targetApi="34">

        <!-- Main Activity: Landscape + Immersive for RC Plus -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden"
            android:keepScreenOn="true"
            android:theme="@style/Theme.DroneCollector.Immersive">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Operator Mode Activity -->
        <activity
            android:name=".ui.OperatorModeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:keepScreenOn="true"
            android:theme="@style/Theme.DroneCollector.Immersive"
            android:parentActivityName=".MainActivity" />

        <!-- Diagnostics Activity -->
        <activity
            android:name=".ui.DiagnosticsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:keepScreenOn="true"
            android:theme="@style/Theme.DroneCollector.Immersive"
            android:parentActivityName=".MainActivity" />

        <!-- Foreground Service: dataSync e o tipo mais compativel com Android 10-14 -->
        <service
            android:name=".service.DroneCollectorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:label="@string/service_name"
            android:description="@string/service_description"
            android:stopWithTask="false" />

        <!-- Accessibility Service -->
        <service
            android:name=".service.DroneAccessibilityService"
            android:enabled="true"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Floating button overlay service -->
        <service
            android:name=".view.FloatingButtonService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:label="@string/floating_service_label" />

        <!-- Boot Receiver: auto-start on RC Plus power-on -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Crash Recovery Receiver -->
        <receiver
            android:name=".util.CrashRecoveryReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dronemonitor.collector.ACTION_RECOVER_SERVICE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
